# ─── APIndex Configuration ─────────────────────────────────────────
# Copy this file to .env and update the values below.
# Required fields are marked with (REQUIRED).

# ─── Application ───────────────────────────────────────────────────
APP_NAME=APIndex
DEBUG=false
ENVIRONMENT=production

# ─── Security (REQUIRED) ──────────────────────────────────────────
# Generate with: openssl rand -base64 32
SECRET_KEY=CHANGE-ME-generate-a-random-string

# ─── Database ──────────────────────────────────────────────────────
POSTGRES_USER=apindex
POSTGRES_PASSWORD=apindex
POSTGRES_DB=apindex

# ─── First Admin User (REQUIRED) ──────────────────────────────────
# Created automatically on first startup.
FIRST_SUPERUSER_EMAIL=admin@yourcompany.com
FIRST_SUPERUSER_PASSWORD=CHANGE-ME

# ─── Registration ─────────────────────────────────────────────────
# Set to false to disable self-registration (invite-only mode).
REGISTRATION_ENABLED=true

# ─── Port ─────────────────────────────────────────────────────────
# The port APIndex will be available on.
PORT=80

# ─── CORS ─────────────────────────────────────────────────────────
# Add your domain if accessing from a different origin.
# CORS_ORIGINS=["https://apindex.yourcompany.com"]

# ─── License (Optional) ───────────────────────────────────────────
# Activate a Pro/Business license for premium features.
# Get a license at https://apindex.dev/pricing
# LICENSE_KEY=APIDX-XXXX-XXXX-XXXX
# INSTANCE_NAME=your-license-id-uuid

# ─── License Server ───────────────────────────────────────────────
# Default points to the hosted license server. No change needed.
LICENSE_SERVER_URL=https://license.apindex.dev

# ─── Frontend URL ─────────────────────────────────────────────────
# Used for Stripe checkout redirects. Set to your public URL.
# FRONTEND_URL=https://apindex.yourcompany.com

# ─── LDAP (Optional — Business/Enterprise) ────────────────────────
# LDAP_ENABLED=true
# LDAP_SERVER_URL=ldap://ldap.yourcompany.com:389
# LDAP_BIND_DN=cn=readonly,dc=yourcompany,dc=com
# LDAP_BIND_PASSWORD=your-bind-password
# LDAP_USER_SEARCH_BASE=ou=users,dc=yourcompany,dc=com
# LDAP_USER_SEARCH_FILTER=(uid={username})
# LDAP_USE_SSL=false
# LDAP_START_TLS=true

# ─── Branding (Optional) ──────────────────────────────────────────
# BRANDING_LOGO_URL=https://yourcompany.com/logo.png
# BRANDING_PRIMARY_COLOR=#3b82f6
# BRANDING_ACCENT_COLOR=#8b5cf6
# BRANDING_FONT_FAMILY=Inter, sans-serif

# ─── Audit Log ────────────────────────────────────────────────────
# Days to retain audit logs. 0 = keep forever.
AUDIT_RETENTION_DAYS=90
